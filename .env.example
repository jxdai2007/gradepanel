# gradepanel environment variables
# Copy to .env.local and fill in values. Never commit .env.local.

# OpenRouter — gateway for all panel LLMs (Claude Sonnet 4.5, Gemini 2.5, GPT-4o)
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenAI (only if calling embeddings directly; otherwise embeddings go via OpenRouter)
# OPENAI_API_KEY=sk-...

# Google AI (optional — direct Gemini API for cheaper embedding cost)
# GOOGLE_API_KEY=

# Storage (defaults work for local dev; override for prod)
GRADEPANEL_DB_PATH=./data/graph.db
GRADEPANEL_BOOTSTRAP_TIMEOUT_MS=60000
GRADEPANEL_PANEL_TIMEOUT_MS=15000

# Vercel deploy
NEXT_PUBLIC_APP_URL=http://localhost:3000
